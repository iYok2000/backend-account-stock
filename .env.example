# Production: ตั้ง APP_ENV=production เพื่อบังคับ JWT_SECRET (ห้ามใช้ค่า dev)
# APP_ENV=production

# JWT (required in production)
JWT_SECRET=your-256-bit-secret-here

# Database — PostgreSQL or Supabase (see docs/SUPABASE.md)
# Local Postgres:
# DATABASE_URL=postgres://user:password@localhost:5432/account_stock?sslmode=disable
# Supabase (Dashboard → Project Settings → Database → Connection string, add ?sslmode=require):
# SUPABASE_DB_URL=postgres://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Or: DATABASE_URL=postgres://...
SUPABASE_DB_URL=

# Server (optional; default 8080). Many hosts set PORT automatically.
# PORT=8080

# ========== CORS (ต้องตรงกับ URL ที่เปิดหน้าบ้าน) ==========
# คั่นหลาย origin ด้วย comma. ว่าง = อนุญาต http://localhost:*, http://127.0.0.1:* (ทุกพอร์ต)
# Local — เปิด FE ที่ http://localhost:3000 หรือ http://127.0.0.1:3000:
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# Production — ใส่ origin ของ frontend (เช่น https://your-fe.vercel.app):
# CORS_ORIGIN=https://your-fe.vercel.app
#
# โหลด .env: Go ไม่โหลด .env อัตโนมัติ — รันแบบนี้เพื่อใช้ค่าข้างบน:
#   set -a && source .env && set +a && go run ./cmd/server
# หรือ export CORS_ORIGIN=... ก่อนรัน

# Optional
# JWT_ISSUER=account-stock-be
# JWT_AUDIENCE=account-stock-fe
